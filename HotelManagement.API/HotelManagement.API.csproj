          <PrivateAssets>all</PrivateAssets>
        </PackageReference>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlserver" Version="8.0.26" />
        <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
